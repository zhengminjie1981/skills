# Doc2Md .gitignore
# Portable tools (can be re-downloaded with --auto-install)
bin/

# Python virtual environments
.venv/
venv/
ENV/
env/

# Converted outputs
*.md
!README.md
!SKILL.md
!docs/*.md
!references/*.md
!examples/*.md

# Extracted media
media/

# Test documents
test_docs/
tests/input/
docs/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Temporary files
*.tmp
*.bak
nul

# Archive (optional - uncomment if you don't want to track archive)
# docs/_archive/
