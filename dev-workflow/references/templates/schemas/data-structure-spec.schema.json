{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/schemas/data-structure-spec.schema.json",
  "title": "数据结构规范",
  "description": "L2 规范级文档的 JSON Schema 定义",
  "type": "object",
  "required": ["title", "documentPosition", "coreDataStructures", "versionHistory"],
  "properties": {
    "title": {
      "type": "string",
      "description": "文档标题",
      "examples": ["数据结构规范"]
    },
    "documentPosition": {
      "type": "object",
      "description": "文档定位说明",
      "required": ["level", "question", "parentDocument", "childDocument"],
      "properties": {
        "level": {
          "type": "string",
          "const": "L2",
          "description": "文档层级"
        },
        "question": {
          "type": "string",
          "description": "回答的问题",
          "examples": ["跨模块数据结构的权威定义"]
        },
        "parentDocument": {
          "type": "string",
          "description": "上位文档链接",
          "format": "uri-reference"
        },
        "childDocument": {
          "type": "string",
          "description": "下游文档链接",
          "format": "uri-reference"
        }
      }
    },
    "coreDataStructures": {
      "type": "array",
      "description": "核心数据结构",
      "items": {
        "type": "object",
        "required": ["name", "definition", "fieldDescriptions", "constraints", "usageExample", "usedBy"],
        "properties": {
          "name": {
            "type": "string",
            "description": "数据结构名称",
            "pattern": "^[A-Z][a-zA-Z0-9]*$"
          },
          "definition": {
            "type": "string",
            "description": "数据结构定义（代码）"
          },
          "fieldDescriptions": {
            "type": "array",
            "description": "字段说明",
            "items": {
              "type": "object",
              "required": ["field", "type", "required", "description"],
              "properties": {
                "field": {
                  "type": "string",
                  "description": "字段名"
                },
                "type": {
                  "type": "string",
                  "description": "字段类型"
                },
                "required": {
                  "type": "boolean",
                  "description": "是否必填"
                },
                "description": {
                  "type": "string",
                  "description": "字段说明"
                }
              }
            }
          },
          "constraints": {
            "type": "array",
            "description": "约束条件",
            "items": {
              "type": "string"
            }
          },
          "usageExample": {
            "type": "string",
            "description": "使用示例（代码）"
          },
          "usedBy": {
            "type": "array",
            "description": "被以下模块使用",
            "items": {
              "type": "string",
              "format": "uri-reference"
            }
          }
        }
      }
    },
    "versionHistory": {
      "type": "array",
      "description": "版本历史",
      "items": {
        "type": "object",
        "required": ["version", "date", "description"],
        "properties": {
          "version": {
            "type": "string",
            "description": "版本号",
            "pattern": "^v\\d+\\.\\d+$"
          },
          "date": {
            "type": "string",
            "description": "日期",
            "format": "date"
          },
          "description": {
            "type": "string",
            "description": "变更说明（包含影响范围）"
          }
        }
      }
    }
  }
}
